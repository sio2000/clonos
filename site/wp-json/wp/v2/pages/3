{"id":3,"date":"2021-10-06T09:06:43","date_gmt":"2021-10-06T09:06:43","guid":{"rendered":"https:\/\/thepoumaacademy.disolt.eu\/?page_id=3"},"modified":"2022-03-08T12:49:46","modified_gmt":"2022-03-08T09:49:46","slug":"oroi-xrisis","status":"publish","type":"page","link":"https:\/\/thepoumaacademy.com\/oroi-xrisis\/","title":{"rendered":"\u039f\u03a1\u039f\u0399 \u03a7\u03a1\u0397\u03a3\u0397\u03a3"},"content":{"rendered":"<div class='flex_column av-4t4l-54a98e111d90132a87a8019a59905f9f av_one_full  avia-builder-el-0  avia-builder-el-no-sibling  first flex_column_div '   id=\"pouma-oroi-sec\"  ><section class=\"av_textblock_section \"  itemscope=\"itemscope\" itemtype=\"https:\/\/schema.org\/CreativeWork\" ><div class='avia_textblock  '   itemprop=\"text\" ><div class=\"fusion-row\">\n<section id=\"content\">\n<div id=\"post-3\" class=\"post-3 page type-page status-publish hentry\">\n<div class=\"post-content\">\n<h1 id=\"oroi-xrisis\" class=\"fusion-responsive-typography-calculated wp-block-heading\" data-fontsize=\"26\" data-lineheight=\"36.4px\">\u039f\u03a1\u039f\u0399 \u03a7\u03a1\u0397\u03a3\u0397\u03a3<\/h1>\n<p class=\"fusion-responsive-typography-calculated\" data-fontsize=\"26\" data-lineheight=\"36.4px\"><strong style=\"font-size: 16px;\">\u0393\u03b5\u03bd\u03b9\u03ba\u03ac<\/strong><\/p>\n<p>H \u03b9\u03c3\u03c4\u03bf\u03c3\u03b5\u03bb\u03af\u03b4\u03b1 thepoumaacademy.com \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03b5\u03af \u03c4\u03b7\u03bd \u03b7\u03bb\u03b5\u03ba\u03c4\u03c1\u03bf\u03bd\u03b9\u03ba\u03ae \u03c0\u03b1\u03c1\u03bf\u03c5\u03c3\u03af\u03b1 \u03c4\u03b7\u03c2 \u03b1\u03c4\u03bf\u03bc\u03b9\u03ba\u03ae\u03c2 \u03b5\u03bc\u03c0\u03bf\u03c1\u03b9\u03ba\u03ae\u03c2 \u03b5\u03c0\u03b9\u03c7\u03b5\u03af\u03c1\u03b7\u03c3\u03b7\u03c2 \u03bc\u03b5 \u03b5\u03c0\u03c9\u03bd\u03c5\u03bc\u03af\u03b1: \u0393\u03b9\u03b1\u03bd\u03bd\u03bf\u03c5\u03c0\u03bb\u03ac\u03ba\u03b7 \u0394\u03ae\u03bc\u03b7\u03c4\u03c1\u03b1 \u0393\u03b5\u03ce\u03c1\u03b3\u03b9\u03bf\u03c2, \u03b5\u03c0\u03ac\u03b3\u03b3\u03b5\u03bb\u03bc\u03b1: \u03a5\u03c0\u03b7\u03c1\u03b5\u03c3\u03af\u03b5\u03c2 \u039e\u03b5\u03bd\u03cc\u03b3\u03bb\u03c9\u03c3\u03c3\u03b7\u03c2 \u0395\u03ba\u03c0\u03b1\u03af\u03b4\u03b5\u03c5\u03c3\u03b7\u03c2, \u0391\u03a6\u039c: 125688067, \u0394\u039f\u03a5: \u039a\u03b9\u03bb\u03ba\u03af\u03c2 \u03ba\u03b1\u03b9 \u03ad\u03b4\u03c1\u03b1: \u0386\u03b3\u03b9\u03bf\u03c2 \u03a0\u03ad\u03c4\u03c1\u03bf\u03c2 0, \u0395\u03cd\u03c1\u03c9\u03c0\u03bf\u03c2, \u03a4.\u039a.: 61007. \u0395\u03c6\u03b5\u03be\u03ae\u03c2 \u03ba\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03bb\u03cc\u03b3\u03bf\u03c5\u03c2 \u03c3\u03c5\u03bd\u03c4\u03bf\u03bc\u03af\u03b1\u03c2 \u03ba\u03b1\u03bb\u03b5\u03af\u03c4\u03b1\u03b9 \u201c\u03b5\u03c4\u03b1\u03b9\u03c1\u03b5\u03af\u03b1\u201d.<\/p>\n<p>\u03a4\u03b7\u03bb\u03ad\u03c6\u03c9\u03bd\u03bf: +30 699 705 5594, email: ask@thepoumaacademy.com<\/p>\n<p>\u03a0\u03c1\u03b9\u03bd \u03b5\u03b9\u03c3\u03ad\u03bb\u03b8\u03b5\u03c4\u03b5 \u03c3\u03c4\u03bf \u03b7\u03bb\u03b5\u03ba\u03c4\u03c1\u03bf\u03bd\u03b9\u03ba\u03cc \u03bc\u03b1\u03c2 \u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b7\u03bc\u03b1 \u03ba\u03b1\u03b9 \u03c0\u03b5\u03c1\u03b9\u03b7\u03b3\u03b7\u03b8\u03b5\u03af\u03c4\u03b5 \u03c3\u03c4\u03bf\u03bd \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf \u03bc\u03b1\u03c2, \u03c3\u03b1\u03c2 \u03ba\u03b1\u03bb\u03bf\u03cd\u03bc\u03b5 \u03bd\u03b1 \u03c3\u03c5\u03bc\u03b2\u03bf\u03c5\u03bb\u03b5\u03c5\u03c4\u03b5\u03af\u03c4\u03b5 \u03c4\u03bf\u03c5\u03c2 \u03ba\u03ac\u03c4\u03c9\u03b8\u03b9 \u03cc\u03c1\u03bf\u03c5\u03c2 \u03ba\u03b1\u03b9 \u03c0\u03c1\u03bf\u03cb\u03c0\u03bf\u03b8\u03ad\u03c3\u03b5\u03b9\u03c2, \u03c0\u03bf\u03c5 \u03b5\u03c6\u03b1\u03c1\u03bc\u03cc\u03b6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03c4\u03b7 \u03c7\u03c1\u03ae\u03c3\u03b7 \u03c4\u03bf\u03c5 \u03b7\u03bb\u03b5\u03ba\u03c4\u03c1\u03bf\u03bd\u03b9\u03ba\u03bf\u03cd \u03ba\u03b1\u03c4\u03b1\u03c3\u03c4\u03ae\u03bc\u03b1\u03c4\u03bf\u03c2 thepoumaacademy.com. \u0392\u03b5\u03b2\u03b1\u03b9\u03c9\u03b8\u03b5\u03af\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03c3\u03c5\u03bc\u03c6\u03c9\u03bd\u03b5\u03af\u03c4\u03b5 \u03bc\u03b5 \u03c4\u03bf\u03c5\u03c2 \u03ba\u03ac\u03c4\u03c9\u03b8\u03b9 \u03cc\u03c1\u03bf\u03c5\u03c2 \u03ba\u03b1\u03b9 \u03c0\u03c1\u03bf\u03cb\u03c0\u03bf\u03b8\u03ad\u03c3\u03b5\u03b9\u03c2, \u03b4\u03b9\u03cc\u03c4\u03b9 \u03b7 \u03c0\u03b5\u03c1\u03b1\u03b9\u03c4\u03ad\u03c1\u03c9 \u03c7\u03c1\u03ae\u03c3\u03b7 \u03ba\u03b1\u03b9 \u03b7 \u03c0\u03b5\u03c1\u03b9\u03ae\u03b3\u03b7\u03c3\u03b7 \u03c3\u03b1\u03c2 \u03c3\u03c4\u03bf\u03bd \u03c0\u03b1\u03c1\u03b1\u03c0\u03ac\u03bd\u03c9 \u03b9\u03c3\u03c4\u03cc\u03c4\u03bf\u03c0\u03bf \u03c3\u03c5\u03bd\u03b5\u03c0\u03ac\u03b3\u03b5\u03c4\u03b1\u03b9 \u03c4\u03b7\u03bd \u03c1\u03b7\u03c4\u03ae \u03ba\u03b1\u03b9 \u03b1\u03bd\u03b5\u03c0\u03b9\u03c6\u03cd\u03bb\u03b1\u03ba\u03c4\u03b7 \u03c3\u03c5\u03b3\u03ba\u03b1\u03c4\u03ac\u03b8\u03b5\u03c3\u03b7 \u03ba\u03b1\u03b9 \u03c3\u03c5\u03bd\u03b1\u03af\u03bd\u03b5\u03c3\u03b7 \u03c3\u03b1\u03c2 \u03bc\u03b5 \u03b1\u03c5\u03c4\u03bf\u03cd\u03c2.<\/p>\n<p>O \u03ba\u03ac\u03c4\u03bf\u03c7\u03bf\u03c2 \u03c4\u03b7\u03c2 \u03b9\u03c3\u03c4\u03bf\u03c3\u03b5\u03bb\u03af\u03b4\u03b1\u03c2 \u03b4\u03b9\u03b1\u03c4\u03b7\u03c1\u03b5\u03af \u03c4\u03bf \u03b4\u03b9\u03ba\u03b1\u03af\u03c9\u03bc\u03b1 \u03bd\u03b1 \u03c4\u03c1\u03bf\u03c0\u03bf\u03c0\u03bf\u03b9\u03b5\u03af \u03bc\u03bf\u03bd\u03bf\u03bc\u03b5\u03c1\u03ce\u03c2 \u03ae \u03bd\u03b1 \u03b1\u03bd\u03b1\u03bd\u03b5\u03ce\u03bd\u03b5\u03b9 \u03c4\u03bf\u03c5\u03c2 \u03c0\u03b1\u03c1\u03cc\u03bd\u03c4\u03b5\u03c2 \u03cc\u03c1\u03bf\u03c5\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03b9\u03c2 \u03c0\u03c1\u03bf\u03cb\u03c0\u03bf\u03b8\u03ad\u03c3\u03b5\u03b9\u03c2 \u03c4\u03c9\u03bd \u03c3\u03c5\u03bd\u03b1\u03bb\u03bb\u03b1\u03b3\u03ce\u03bd. \u0391\u03bd\u03b1\u03bb\u03b1\u03bc\u03b2\u03ac\u03bd\u03b5\u03b9 \u03b5\u03c0\u03af\u03c3\u03b7\u03c2 \u03c4\u03b7\u03bd \u03c5\u03c0\u03bf\u03c7\u03c1\u03ad\u03c9\u03c3\u03b7 \u03bd\u03b1 \u03b5\u03bd\u03b7\u03bc\u03b5\u03c1\u03ce\u03bd\u03b5\u03b9 \u03c4\u03bf\u03c5\u03c2 \u03c7\u03c1\u03ae\u03c3\u03c4\u03b5\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03c5\u03c7\u03cc\u03bd \u03c4\u03c1\u03bf\u03c0\u03bf\u03c0\u03bf\u03b9\u03ae\u03c3\u03b5\u03b9\u03c2 \u03ba\u03b1\u03b8\u03ce\u03c2 \u03ba\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03bf\u03c0\u03bf\u03b9\u03b1\u03b4\u03ae\u03c0\u03bf\u03c4\u03b5 \u03b1\u03bb\u03bb\u03b1\u03b3\u03ae \u03c4\u03bf\u03c5 \u03b7\u03bb\u03b5\u03ba\u03c4\u03c1\u03bf\u03bd\u03b9\u03ba\u03bf\u03cd \u03ba\u03b1\u03c4\u03b1\u03c3\u03c4\u03ae\u03bc\u03b1\u03c4\u03bf\u03c2. \u0394\u03b5\u03c3\u03bc\u03b5\u03cd\u03b5\u03c4\u03b1\u03b9 \u03c9\u03c2 \u03c0\u03c1\u03bf\u03c2 \u03c4\u03b7\u03bd \u03c0\u03bb\u03b7\u03c1\u03cc\u03c4\u03b7\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03c4\u03b7\u03bd \u03b5\u03b3\u03ba\u03c5\u03c1\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c4\u03c9\u03bd \u03c0\u03bb\u03b7\u03c1\u03bf\u03c6\u03bf\u03c1\u03b9\u03ce\u03bd \u03c0\u03bf\u03c5 \u03c0\u03b1\u03c1\u03b1\u03c4\u03af\u03b8\u03b5\u03bd\u03c4\u03b1\u03b9, \u03c4\u03cc\u03c3\u03bf \u03cc\u03c3\u03bf\u03bd \u03b1\u03c6\u03bf\u03c1\u03ac \u03c4\u03b7\u03bd \u03cd\u03c0\u03b1\u03c1\u03be\u03b7 \u03c4\u03c9\u03bd \u03bf\u03c5\u03c3\u03b9\u03c9\u03b4\u03ce\u03bd \u03c7\u03b1\u03c1\u03b1\u03ba\u03c4\u03b7\u03c1\u03b9\u03c3\u03c4\u03b9\u03ba\u03ce\u03bd \u03c0\u03bf\u03c5 \u03ba\u03b1\u03c4\u03ac \u03c0\u03b5\u03c1\u03af\u03c0\u03c4\u03c9\u03c3\u03b7 \u03c0\u03b5\u03c1\u03b9\u03b3\u03c1\u03ac\u03c6\u03bf\u03bd\u03c4\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03ba\u03ac\u03b8\u03b5 \u03c0\u03c1\u03bf\u03ca\u03cc\u03bd \u03c0\u03bf\u03c5 \u03b4\u03b9\u03b1\u03b8\u03ad\u03c4\u03b5\u03b9, \u03c5\u03c0\u03cc \u03c4\u03b7\u03bd \u03b5\u03c0\u03b9\u03c6\u03cd\u03bb\u03b1\u03be\u03b7 \u03c4\u03c5\u03c7\u03cc\u03bd \u03c4\u03b5\u03c7\u03bd\u03b9\u03ba\u03ce\u03bd \u03ae \u03c4\u03c5\u03c0\u03bf\u03b3\u03c1\u03b1\u03c6\u03b9\u03ba\u03ce\u03bd \u03bb\u03b1\u03b8\u03ce\u03bd, \u03c0\u03bf\u03c5 \u03ad\u03c7\u03bf\u03c5\u03bd \u03b4\u03b9\u03b1\u03c6\u03cd\u03b3\u03b5\u03b9 \u03c4\u03b7\u03c2 \u03c0\u03c1\u03bf\u03c3\u03bf\u03c7\u03ae\u03c2 \u03ae \u03ad\u03c7\u03bf\u03c5\u03bd \u03c0\u03c1\u03bf\u03ba\u03cd\u03c8\u03b5\u03b9 \u03b1\u03ba\u03bf\u03cd\u03c3\u03b9\u03b1 \u03ae \u03bb\u03cc\u03b3\u03c9 \u03c4\u03c5\u03c7\u03cc\u03bd \u03b4\u03b9\u03b1\u03ba\u03bf\u03c0\u03ce\u03bd \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03af\u03b1\u03c2 \u03c4\u03b7\u03c2 \u03b9\u03c3\u03c4\u03bf\u03c3\u03b5\u03bb\u03af\u03b4\u03b1\u03c2 \u03b5\u03ba \u03bb\u03cc\u03b3\u03c9\u03bd \u03b1\u03bd\u03c9\u03c4\u03ad\u03c1\u03b1\u03c2 \u03b2\u03af\u03b1\u03c2.<\/p>\n<p>\u0397 \u03b5\u03c4\u03b1\u03b9\u03c1\u03af\u03b1 \u03b4\u03b5\u03bd \u03c6\u03ad\u03c1\u03b5\u03b9 \u03b5\u03c5\u03b8\u03cd\u03bd\u03b7 \u03b3\u03b9\u03b1 \u03c4\u03c5\u03c7\u03cc\u03bd \u03c4\u03b5\u03c7\u03bd\u03b9\u03ba\u03ac \u03c0\u03c1\u03bf\u03b2\u03bb\u03ae\u03bc\u03b1\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03c4\u03c5\u03c7\u03cc\u03bd \u03c0\u03b1\u03c1\u03bf\u03c5\u03c3\u03b9\u03b1\u03c3\u03b8\u03bf\u03cd\u03bd \u03c3\u03c4\u03bf\u03c5\u03c2 \u03c7\u03c1\u03ae\u03c3\u03c4\u03b5\u03c2 \u03cc\u03c4\u03b1\u03bd \u03b5\u03c0\u03b9\u03c7\u03b5\u03b9\u03c1\u03bf\u03cd\u03bd \u03c4\u03b7\u03bd \u03c0\u03c1\u03cc\u03c3\u03b2\u03b1\u03c3\u03b7 \u03c3\u03c4\u03bf\u03bd \u03b4\u03b9\u03ba\u03c4\u03c5\u03b1\u03ba\u03cc \u03c4\u03b7\u03c2 \u03c4\u03cc\u03c0\u03bf \u03ba\u03b1\u03b9 \u03ba\u03b1\u03c4\u03ac \u03c4\u03b7\u03bd \u03b4\u03b9\u03ac\u03c1\u03ba\u03b5\u03b9\u03b1 \u03b1\u03c5\u03c4\u03ae\u03c2 \u03ba\u03b1\u03b9 \u03ad\u03c7\u03bf\u03c5\u03bd \u03c3\u03c7\u03ad\u03c3\u03b7 \u03bc\u03b5 \u03c4\u03b7 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03af\u03b1 \u03ae \u03c3\u03c5\u03bc\u03b2\u03b1\u03c4\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c4\u03b7\u03c2 \u03b4\u03b9\u03ba\u03ae\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03c5\u03c0\u03bf\u03b4\u03bf\u03bc\u03ae\u03c2. \u0395\u03c0\u03af\u03c3\u03b7\u03c2 \u03bf\u03c5\u03b4\u03b5\u03bc\u03af\u03b1 \u03b5\u03c5\u03b8\u03cd\u03bd\u03b7 \u03c6\u03ad\u03c1\u03bf\u03c5\u03bc\u03b5 \u03b3\u03b9\u03b1 \u03c0\u03c1\u03ac\u03be\u03b5\u03b9\u03c2 \u03ae \u03c0\u03b1\u03c1\u03b1\u03bb\u03b5\u03af\u03c8\u03b5\u03b9\u03c2 \u03c4\u03c1\u03af\u03c4\u03c9\u03bd \u03ba\u03b1\u03b9 \u03b9\u03b4\u03b9\u03b1\u03af\u03c4\u03b5\u03c1\u03b1 \u03bc\u03b7 \u03b5\u03c0\u03b9\u03c4\u03c1\u03b5\u03c0\u03cc\u03bc\u03b5\u03bd\u03b5\u03c2 \u03c0\u03b1\u03c1\u03b5\u03bc\u03b2\u03ac\u03c3\u03b5\u03b9\u03c2 \u03c4\u03c1\u03af\u03c4\u03c9\u03bd \u03c3\u03b5 \u03c0\u03c1\u03bf\u03ca\u03cc\u03bd\u03c4\u03b1 \u03ae\/\u03ba\u03b1\u03b9 \u03c0\u03bb\u03b7\u03c1\u03bf\u03c6\u03bf\u03c1\u03af\u03b5\u03c2 \u03c0\u03bf\u03c5 \u03b4\u03b9\u03b1\u03c4\u03af\u03b8\u03b5\u03bd\u03c4\u03b1\u03b9.<\/p>\n<p><strong>\u0394\u03b9\u03b1\u03b8\u03b5\u03c3\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1<br \/><\/strong>\u0391\u03bd\u03ac\u03bc\u03b5\u03c3\u03b1 \u03c3\u03c4\u03b1 \u03c0\u03c1\u03bf\u03ca\u03cc\u03bd\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03b2\u03ac\u03bb\u03bb\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c3\u03c4\u03bf \u03b7\u03bb\u03b5\u03ba\u03c4\u03c1\u03bf\u03bd\u03b9\u03ba\u03cc \u03bc\u03b1\u03c2 \u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b7\u03bc\u03b1 \u03c5\u03c0\u03ac\u03c1\u03c7\u03b5\u03b9 \u03b7 \u03c0\u03b9\u03b8\u03b1\u03bd\u03cc\u03c4\u03b7\u03c4\u03b1 \u03ba\u03ac\u03c0\u03bf\u03b9\u03bf \u03bd\u03b1 \u03ad\u03c7\u03b5\u03b9 \u03b5\u03be\u03b1\u03bd\u03c4\u03bb\u03b7\u03b8\u03b5\u03af \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03bc\u03b7\u03bd \u03ad\u03c7\u03b5\u03b9 \u03b5\u03bd\u03b7\u03bc\u03b5\u03c1\u03c9\u03b8\u03b5\u03af \u03b7 \u03b9\u03c3\u03c4\u03bf\u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u03ad\u03bb\u03bb\u03b5\u03b9\u03c8\u03ae \u03c4\u03bf\u03c5. \u03a5\u03c0\u03ac\u03c1\u03c7\u03b5\u03b9 \u03b5\u03c0\u03af\u03c3\u03b7\u03c2 \u03b7 \u03c0\u03b9\u03b8\u03b1\u03bd