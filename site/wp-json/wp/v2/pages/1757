{"id":1757,"date":"2022-02-19T19:57:24","date_gmt":"2022-02-19T16:57:24","guid":{"rendered":"https:\/\/thepoumaacademy.com\/?page_id=1757"},"modified":"2022-04-26T20:47:37","modified_gmt":"2022-04-26T17:47:37","slug":"agglika-proforiki-epikoinonia","status":"publish","type":"page","link":"https:\/\/thepoumaacademy.com\/agglika-proforiki-epikoinonia\/","title":{"rendered":"\u0391\u03b3\u03b3\u03bb\u03b9\u03ba\u03ac \u03b3\u03b9\u03b1 \u03c0\u03c1\u03bf\u03c6\u03bf\u03c1\u03b9\u03ba\u03ae \u03b5\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1"},"content":{"rendered":"<section class=\"av_textblock_section \"  itemscope=\"itemscope\" itemtype=\"https:\/\/schema.org\/CreativeWork\" ><div class='avia_textblock  '   itemprop=\"text\" ><h2>\u0391\u03b3\u03b3\u03bb\u03b9\u03ba\u03ac \u03b3\u03b9\u03b1 \u03c0\u03c1\u03bf\u03c6\u03bf\u03c1\u03b9\u03ba\u03ae \u03b5\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1<\/h2>\n<p><span style=\"font-size: 12pt; font-family: 'book antiqua', palatino, serif;\">&#8220;\u0388\u03c7\u03c9 \u03ba\u03ac\u03bd\u03b5\u03b9 \u0391\u03b3\u03b3\u03bb\u03b9\u03ba\u03ac \u03b1\u03bb\u03bb\u03ac \u03b4\u03b5 \u03bc\u03c0\u03bf\u03c1\u03c9 \u03bd\u03b1 \u03bc\u03b9\u03bb\u03ae\u03c3\u03c9&#8221;, &#8220;\u03c6\u03bf\u03b2\u03ac\u03bc\u03b1\u03b9 \u03bc\u03ae\u03c0\u03c9\u03c2 \u03ba\u03ac\u03bd\u03c9 \u03ba\u03ac\u03c0\u03bf\u03b9\u03bf \u03bb\u03ac\u03b8\u03bf\u03c2 \u03ba\u03b1\u03b9 \u03bd\u03c4\u03c1\u03ad\u03c0\u03bf\u03bc\u03b1\u03b9&#8221; &#8220;\u03c3\u03c5\u03bd\u03ae\u03b8\u03c9\u03c2 \u03bc\u03cc\u03bd\u03bf \u03b1\u03ba\u03bf\u03cd\u03c9 \u03ba\u03b1\u03b9 \u03b1\u03c0\u03bf\u03c6\u03b5\u03cd\u03b3\u03c9 \u03bd\u03b1 \u03bc\u03b9\u03bb\u03ae\u03c3\u03c9&#8221;, &#8220;\u03b1\u03bd \u03ba\u03b1\u03b9 \u03ba\u03b1\u03c4\u03b1\u03bb\u03b1\u03b2\u03b1\u03af\u03bd\u03c9 \u03c4\u03af \u03bc\u03bf\u03c5 \u03bb\u03ad\u03bd\u03b5, \u03cc\u03c4\u03b1\u03bd \u03c0\u03c1\u03bf\u03c3\u03c0\u03b1\u03b8\u03ae\u03c3\u03c9 \u03bd\u03b1 \u03bc\u03b9\u03bb\u03ae\u03c3\u03c9 \u03b4\u03b5 \u03bc\u03c0\u03bf\u03c1\u03ce \u03bd\u03b1 \u03c0\u03c9 \u03bb\u03ad\u03be\u03b7&#8221;. \u0391\u03c5\u03c4\u03ad\u03c2 \u03bf\u03b9 \u03c0\u03c1\u03bf\u03c4\u03ac\u03c3\u03b5\u03b9\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c7\u03b1\u03c1\u03b1\u03ba\u03c4\u03b7\u03c1\u03b9\u03c3\u03c4\u03b9\u03ba\u03ad\u03c2 \u03c4\u03bf\u03c5 \u03c0\u03c9\u03c2 \u03c0\u03b5\u03c1\u03b9\u03b3\u03c1\u03ac\u03c6\u03bf\u03c5\u03bd \u03bf\u03b9 \u03bc\u03b1\u03b8\u03b7\u03c4\u03ad\u03c2 \u03bc\u03b1\u03c2 \u03c4\u03b1 \u03c3\u03c5\u03bd\u03b1\u03b9\u03c3\u03b8\u03ae\u03bc\u03b1\u03c4\u03ac \u03c4\u03bf\u03c5\u03c2, \u03cc\u03c4\u03b1\u03bd \u03c0\u03c1\u03bf\u03c3\u03c0\u03b1\u03b8\u03bf\u03cd\u03bd \u03bd\u03b1 \u03bc\u03b9\u03bb\u03ae\u03c3\u03bf\u03c5\u03bd.<\/span><\/p>\n<p><span style=\"font-size: 12pt; font-family: 'book antiqua', palatino, serif;\">\u03a0\u03c9\u03c2 \u03c4\u03bf \u03b1\u03bd\u03c4\u03b9\u03bc\u03b5\u03c4\u03c9\u03c0\u03af\u03b6\u03bf\u03c5\u03bc\u03b5 \u03c3\u03c4\u03bf The Pouma Academy?<\/span><\/p>\n<p><span style=\"font-size: 12pt; font-family: 'book antiqua', palatino, serif;\">\u039e\u03b5\u03ba\u03b9\u03bd\u03ac\u03bc\u03b5 \u03b1\u03c0\u03cc \u03c4\u03bf \u03cc\u03c4\u03b9 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03bc\u03b9\u03bb\u03ae\u03c3\u03c9 \u03c3\u03c9\u03c3\u03c4\u03ac, \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03c0\u03c1\u03ce\u03c4\u03b1 \u03bd\u03b1 \u03b1\u03ba\u03bf\u03cd\u03c3\u03c9 \u03c4\u03b7\u03bd \u03b1\u03c5\u03b8\u03b5\u03bd\u03c4\u03b9\u03ba\u03ae \u03b3\u03bb\u03ce\u03c3\u03c3\u03b1. \u0388\u03bd\u03b1 \u03bc\u03c9\u03c1\u03cc \u03b1\u03c0\u03cc \u03c4\u03b7 \u03c3\u03c4\u03b9\u03b3\u03bc\u03ae \u03c0\u03bf\u03c5 \u03b3\u03b5\u03bd\u03bd\u03b9\u03ad\u03c4\u03b1\u03b9, \u03b1\u03ba\u03bf\u03cd\u03b5\u03b9 \u03c3\u03c5\u03bd\u03b5\u03c7\u03ce\u03c2 \u03c4\u03b7 \u03bc\u03b7\u03c4\u03c1\u03b9\u03ba\u03ae \u03c4\u03bf\u03c5 \u03b3\u03bb\u03ce\u03c3\u03c3\u03b1 \u03ba\u03b1\u03b9 \u03bc\u03b5\u03c4\u03ac \u03b1\u03c0\u03cc \u03ad\u03bd\u03b1 \u03c3\u03b7\u03bc\u03b5\u03af\u03bf \u03b1\u03c1\u03c7\u03af\u03b6\u03b5\u03b9 \u03bd\u03b1 \u03bc\u03b9\u03bb\u03ac\u03b5\u03b9. \u039a\u03b1\u03c4\u03ac \u03c0\u03b1\u03c1\u03cc\u03bc\u03bf\u03b9\u03bf \u03c4\u03c1\u03cc\u03c0\u03bf \u03c7\u03c4\u03af\u03b6\u03b5\u03c4\u03b1\u03b9 \u03b7 \u03c0\u03c1\u03bf\u03c6\u03bf\u03c1\u03b9\u03ba\u03ae \u03bc\u03b1\u03c2 \u03b5\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1, \u03b4\u03b7\u03bb\u03b1\u03b4\u03ae \u03b1\u03c0\u03cc \u03c4\u03bf \u03ac\u03ba\u03bf\u03c5\u03c3\u03bc\u03b1. \u03a3\u03c5\u03bd\u03c4\u03bf\u03bd\u03b9\u03b6\u03cc\u03bc\u03b1\u03c3\u03c4\u03b5 \u03bc\u03b5 tv news channels, \u03cc\u03c0\u03c9\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c4\u03bf CNN, BBC, Euronews \u03b1\u03bb\u03bb\u03ac \u03ba\u03b1\u03b9 \u03bc\u03b5 YouTube channels, TikTok, \u03c1\u03b1\u03b4\u03b9\u03bf\u03c6\u03c9\u03bd\u03b9\u03ba\u03bf\u03cd\u03c2 \u03c3\u03c4\u03b1\u03b8\u03bc\u03bf\u03cd\u03c2 \u03ba\u03b1\u03b9 \u03ba\u03b1\u03b8\u03b7\u03bc\u03b5\u03c1\u03b9\u03bd\u03ac \u03b1\u03ba\u03bf\u03cd\u03bc\u03b5 \u03c4\u03b7 \u03b3\u03bb\u03ce\u03c3\u03c3\u03b1 \u03cc\u03c0\u03c9\u03c2 \u03c4\u03b7 \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03bf\u03c0\u03bf\u03b9\u03bf\u03cd\u03bd \u03c3\u03c4\u03b7\u03bd \u0391\u03bc\u03b5\u03c1\u03b9\u03ba\u03ae, \u03b3\u03b9\u03b1 \u03c0\u03b1\u03c1\u03ac\u03b4\u03b5\u03b9\u03b3\u03bc\u03b1. \u03a6\u03c5\u03c3\u03b9\u03ba\u03ac \u03ba\u03b1\u03b9 \u03c3\u03c4\u03bf \u03c0\u03c1\u03ce\u03c4\u03bf \u03c3\u03c4\u03ac\u03b4\u03b9\u03bf, \u03c4\u03bf \u03b5\u03c0\u03af\u03c0\u03b5\u03b4\u03bf \u03ba\u03b1\u03c4\u03b1\u03bd\u03cc\u03b7\u03c3\u03b7\u03c2 \u03b5\u03af\u03bd\u03b1\u03b9 \u03c7\u03b1\u03bc\u03b7\u03bb\u03cc \u03b1\u03bb\u03bb\u03ac \u03c3\u03c4\u03b1\u03b4\u03b9\u03b1\u03ba\u03ac \u03c4\u03bf \u03b1\u03c5\u03c4\u03af \u03bc\u03b1\u03c2 \u03b5\u03be\u03b1\u03c3\u03ba\u03b5\u03af\u03c4\u03b1\u03b9 \u03ba\u03b1\u03b9 \u03b2\u03b5\u03bb\u03c4\u03b9\u03ce\u03bd\u03b5\u03c4\u03b1\u03b9 \u03b7 \u03c0\u03c1\u03bf\u03c6\u03bf\u03c1\u03ac \u03bc\u03b1\u03c2 \u03b1\u03bb\u03bb\u03ac \u03ba\u03b1\u03b9 \u03b7 \u03c4\u03b1\u03c7\u03cd\u03c4\u03b7\u03c4\u03b1 \u03ba\u03b1\u03c4\u03b1\u03bd\u03cc\u03b7\u03c3\u03b7\u03c2. \u03a4\u03b1\u03c5\u03c4\u03cc\u03c7\u03c1\u03bf\u03bd\u03b1 \u03c3\u03c5\u03b6\u03b7\u03c4\u03ac\u03bc\u03b5 \u03b8\u03ad\u03bc\u03b1\u03c4\u03b1 \u03c4\u03b7\u03c2 \u03ba\u03b1\u03b8\u03b7\u03bc\u03b5\u03c1\u03b9\u03bd\u03cc\u03c4\u03b7\u03c4\u03b1\u03c2, \u03bd\u03ad\u03b1 \u03b1\u03c0\u03cc \u03c4\u03b7\u03bd \u03b5\u03c0\u03b9\u03c3\u03c4\u03ae\u03bc\u03b7 \u03ba\u03b1\u03b9 \u03c4\u03b5\u03c7\u03bd\u03bf\u03bb\u03bf\u03b3\u03af\u03b1, \u03c4\u03b7\u03bd \u03b1\u03b3\u03bf\u03c1\u03ac \u03b5\u03c1\u03b3\u03b1\u03c3\u03af\u03b1\u03c2, \u03c4\u03b7\u03bd \u03c4\u03ad\u03c7\u03bd\u03b7 \u03ba\u03b1\u03b9 \u03b8\u03ad\u03bc\u03b1\u03c4\u03b1 \u03b4\u03b9\u03b1\u03c0\u03c1\u03bf\u03c3\u03c9\u03c0\u03b9\u03ba\u03ce\u03bd \u03c3\u03c7\u03ad\u03c3\u03b5\u03c9\u03bd. \u03a3\u03c4\u03bf Pouma \u03b8\u03b5\u03bb\u03bf\u03cd\u03bc\u03b5 \u03b7 \u03b3\u03bb\u03ce\u03c3\u03c3\u03b1 \u03bd\u03b1 \u03ad\u03c7\u03b5\u03b9 \u03c0\u03b1\u03bb\u03bc\u03cc \u03ba\u03b1\u03b9 \u03b8\u03b5\u03c1\u03bc\u03bf\u03ba\u03c1\u03b1\u03c3\u03af\u03b1, \u03bd\u03b1 \u03b5\u03af\u03bd\u03b1\u03b9 \u03b1\u03c5\u03b8\u03b5\u03bd\u03c4\u03b9\u03ba\u03ae \u03ba\u03b1\u03b9 \u03bc\u03b5 \u03c0\u03c1\u03b1\u03ba\u03c4\u03b9\u03ba\u03ae \u03b1\u03be\u03af\u03b1. \u0397 \u03b3\u03bb\u03c9\u03c3\u03c3\u03bf\u03bc\u03ac\u03b8\u03b5\u03b9\u03b1 \u03b4\u03b5\u03bd \u03c4\u03b5\u03bb\u03b5\u03b9\u03ce\u03bd\u03b5\u03b9 \u03c0\u03bf\u03c4\u03ad, \u03b3\u03b9&#8217; \u03b1\u03c5\u03c4\u03cc \u03ba\u03b1\u03b9 \u03b2\u03ac\u03b6\u03bf\u03c5\u03bc\u03b5 \u03c4\u03b9\u03c2 \u03b2\u03ac\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03bc\u03b1\u03b8\u03b1\u03af\u03bd\u03bf\u03c5\u03bc\u03b5 \u03c3\u03c9\u03c3\u03c4\u03ac