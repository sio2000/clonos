u03b9\u03b4\u03c9 \u03c4\u03b9\u03c2 \u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03b9\u03b5\u03c2 \u03c9\u03c1\u03b5\u03c2 \u03bc\u03b1\u03b8\u03b7\u03bc\u03b1\u03c4\u03c9\u03bd \u03b3\u03b9\u03b1 \u03c6\u03b5\u03c4\u03bf\u03c2 \u03ba\u03b1\u03b9 \u03c3\u03c5\u03bd\u03b5\u03c7\u03b9\u03b6\u03c9 \u03bd\u03b1 \u03b8\u03c5\u03bc\u03b9\u03b6\u03c9 \u03c3\u03c4\u03bf\u03c5\u03c2 \u03bc\u03b1\u03b8\u03b7\u03c4\u03b5\u03c2 \u03bc\u03bf\u03c5 \u03bf\u03c4\u03b9 <strong>\u03b7 \u03b3\u03bb\u03c9\u03c3\u03c3\u03b1 \u03bc\u03b1\u03b8\u03b1\u03b9\u03bd\u03b5\u03c4\u03b1\u03b9 \u03bc\u03b5\u03c3\u03b1 \u03b1\u03c0\u03bf \u03c4\u03b7\u03bd \u03b5\u03c0\u03b1\u03c6\u03b7 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03b9\u03b4\u03b9\u03b1 \u03c4\u03b7 \u03b3\u03bb\u03c9\u03c3\u03c3\u03b1<\/strong>. \u0395\u03b9\u03bd\u03b1\u03b9 \u03c3\u03c7\u03b5\u03b4\u03bf\u03bd \u03b1\u03b4\u03b9\u03b1\u03bd\u03bf\u03b7\u03c4\u03bf \u03bd\u03b1 \u03bc\u03b7 \u03bc\u03c0\u03bf\u03c1\u03bf\u03c5\u03bc\u03b5 \u03bd\u03b1 \u03b4\u03b9\u03b1\u03b2\u03b1\u03c3\u03bf\u03c5\u03bc\u03b5 \u03bc\u03b9\u03b1 \u03b5\u03c6\u03b7\u03bc\u03b5\u03c1\u03b9\u03b4\u03b1 \u03bf\u03c0\u03c9\u03c2 \u03c4\u03bf <em>The New York Times<\/em>, \u03bd\u03b1 \u03bc\u03b7\u03bd \u03bc\u03c0\u03bf\u03c1\u03bf\u03c5\u03bc\u03b5 \u03bd\u03b1 \u03b4\u03bf\u03c5\u03bc\u03b5 \u03b5\u03bd\u03b1 tv series\/documentary \u03c3\u03c4\u03b1 \u0391\u03b3\u03b3\u03bb\u03b9\u03ba\u03b1 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03c0\u03b9\u03c3\u03c4\u03b5\u03c5\u03bf\u03c5\u03bc\u03b5 \u03bf\u03c4\u03b9 \u03be\u03b5\u03c1\u03bf\u03c5\u03bc\u03b5 \u03c4\u03b7 \u03b3\u03bb\u03c9\u03c3\u03c3\u03b1.<\/span><\/p>\n<p><span style=\"font-weight: 400;\">\u00a0\u201c<strong>\u039c\u03b1 \u03ba\u03b1\u03b9 \u03c4\u03b9 \u03b5\u03b3\u03b9\u03bd\u03b5<\/strong>;\u201d, \u03bc\u03c0\u03bf\u03c1\u03b5\u03b9 \u03bd\u03b1 \u03c1\u03c9\u03c4\u03b7\u03c3\u03b5\u03b9 \u03ba\u03b1\u03c0\u03bf\u03b9\u03bf\u03c2, \u201c<strong>\u03b1\u03c5\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03b8\u03b5\u03bb\u03c9 \u03bd\u03b1 \u03c0\u03c9, \u03c0\u03b1\u03bd\u03c9 \u03ba\u03b1\u03c4\u03c9 \u03c4\u03b1 \u03bb\u03b5<\/strong>\u03c9\u201d.<\/span><\/p>\n<p><span style=\"font-weight: 400;\">\u03a3\u03c9\u03c3\u03c4\u03b1! <em>\u03a3\u03c4\u03b7 \u03c3\u03c5\u03bd\u03b5\u03bd\u03c4\u03b5\u03c5\u03be\u03b7 \u03bf\u03bc\u03c9\u03c2 \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03c3\u03bf\u03c5 \u03b6\u03b7\u03c4\u03b7\u03c3\u03bf\u03c5\u03bd \u03bd\u03b1 \u03b4\u03c9\u03c3\u03b5\u03b9\u03c2 \u03c3\u03c4\u03bf Skype<\/em>, \u03c3\u03c4\u03bf video \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03c7\u03c1\u03b5\u03b9\u03b1\u03c3\u03c4\u03b5\u03b9 \u03bd\u03b1 \u03c3\u03c4\u03b5\u03b9\u03bb\u03b5\u03b9\u03c2 \u03b1\u03bd\u03c4\u03b9 \u03b3\u03b9\u03b1 \u03b2\u03b9\u03bf\u03b3\u03c1\u03b1\u03c6\u03b9\u03ba\u03bf, \u03c3\u03c4\u03b1 emails \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03c0\u03c1\u03b5\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03b1\u03c0\u03b1\u03bd\u03c4\u03b7\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b2\u03bf\u03b7\u03b8\u03b7\u03c3\u03b5\u03b9\u03c2 \u03b5\u03bd\u03b1\u03bd \u03c0\u03b5\u03bb\u03b1\u03c4\u03b7 \u03c3\u03bf\u03c5 \u03b8\u03b1 \u03c0\u03c1\u03b5\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03bc\u03b9\u03bb\u03b7\u03c3\u03b5\u03b9\u03c2 \u03c3\u03c9\u03c3\u03c4\u03b1, \u03bf\u03c7\u03b9 \u03c0\u03b5\u03c1\u03b9\u03c0\u03bf\u03c5 \u03c3\u03c9\u03c3\u03c4\u03b1..<\/span><\/p>\n<p><span style=\"font-weight: 400;\">\u0391\u03bb\u03bb\u03b1\u03b3\u03b7 \u03c0\u03bb\u03b5\u03c5\u03c3\u03b7\u03c2 \u03bb\u03bf\u03b9\u03c0\u03bf\u03bd! <strong>\u0394\u03b5\u03c2 \u03c4\u03b7\u03bd \u03b1\u03b3\u03b3\u03bb\u03b9\u03ba\u03b7 \u03b3\u03bb\u03c9\u03c3\u03c3\u03b1 \u03c3\u03b1\u03bd \u03c4\u03bf \u03b4\u03b9\u03b1\u03b2\u03b1\u03c4\u03b7\u03c1\u03b9\u03bf \u03c3\u03bf\u03c5 \u03b3\u03b9\u03b1 \u03ba\u03b1\u03b8\u03b5 \u03bf\u03bd\u03b5\u03b9\u03c1\u03bf, \u03c4\u03b1\u03be\u03b9\u03b4\u03b9, \u03b4\u03bf\u03c5\u03bb\u03b5\u03b9\u03b1 \u03ba\u03b1\u03b9 \u03c3\u03c0\u03bf\u03c5\u03b4\u03b7 \u03c0\u03bf\u03c5 \u03b8\u03b5\u03c2 \u03bd\u03b1 \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03bf\u03c0\u03bf\u03b9\u03b7\u03c3\u03b5\u03b9\u03c2.<\/strong>. \u0394\u03b9\u03b1\u03b2\u03b1\u03c3\u03b5, \u03b1\u03ba\u03bf\u03c5 \u03ba\u03b1\u03b9 \u03b4\u03b5\u03c2 \u03b1\u03c5\u03c4\u03bf \u03c0\u03bf\u03c5 \u03b1\u03ba\u03bf\u03c5\u03b5\u03b9 \u03b5\u03bd\u03b1\u03c2 \u0391\u03bc\u03b5\u03c1\u03b9\u03ba\u03b1\u03bd\u03bf\u03c2 \u03bf\u03c7\u03b9 \u03bf \u0395\u03bb\u03bb\u03b7\u03bd\u03b1\u03c2 \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03c3\u03c0\u03b1\u03b8\u03b5\u03b9 \u03bd\u03b1 \u03bc\u03b1\u03b8\u03b5\u03b9 \u03bc\u03b5\u03c3\u03b1 \u03b1\u03c0\u03bf \u03bb\u03b9\u03c3\u03c4\u03b5\u03c2 \u03bc\u03b5 \u03bb\u03b5\u03be\u03b5\u03b9\u03c2 \u03c0\u03bf\u03c5 \u03b1\u03c0\u03bf\u03c3\u03c4\u03b7\u03b8\u03b9\u03b6\u03b5\u03b9. \u039c\u03b9\u03bc\u03b7\u03c3\u03bf\u03c5 \u03b5\u03bd\u03b1 \u03bc\u03c9\u03c1\u03bf \u03bc\u03bf\u03c5 \u03c0\u03c1\u03c9\u03c4\u03b1 \u03b1\u03ba\u03bf\u03c5\u03b5\u03b9, \u03b1\u03ba\u03bf\u03c5\u03b5\u03b9, \u03b1\u03ba\u03bf\u03c5\u03b5\u03b9 \u03ba\u03b1\u03b9 \u03bc\u03b5\u03c4\u03b1 \u03bc\u03b9\u03bb\u03b1\u03b5\u03b9. \u0391\u03c6\u03b5\u03c3\u03bf\u03c5 \u03c3\u03b5 \u03b5\u03bd\u03b1\u03bd \u03b1\u03bb\u03bb\u03bf \u03ba\u03bf\u03c3\u03bc\u03bf, \u03c0\u03bb\u03b5\u03c5\u03c3\u03b5 \u03c0\u03c1\u03bf\u03bd \u03c4\u03b7\u03bd \u03bf\u03c5\u03c3\u03b9\u03b1 \u03bf\u03c7\u03b9 \u03c4\u03b1 \u03c0\u03c4\u03c5\u03c7\u03b9\u03b1 (\u03bc\u03bf\u03bd\u03bf..). <\/span><\/p>\n<blockquote><p><span style=\"font-weight: 400;\">\u03a0\u03b1\u03b9\u03be\u03b5 \u03b5\u03bd\u03b1 video game, \u03b5\u03bd\u03b1 app \u03c3\u03c4\u03bf \u03ba\u03b9\u03bd\u03b7\u03c4\u03bf \u03c3\u03bf\u03c5, \u03b4\u03b5\u03c2 \u03bc\u03b9\u03b1 \u03c3\u03b5\u03b9\u03c1\u03b1, \u03c0\u03b1\u03c1\u03b5 \u03b5\u03bd\u03b1 \u03b2\u03b9\u03b2\u03bb\u03b9\u03bf, \u03b1\u03ba\u03bf\u03c5\u03c3\u03b5 \u03b5\u03bd\u03b1 audiobook, \u03ba\u03b1\u03bd\u03b5 \u03ba\u03b1\u03c4\u03b9 \u03c0\u03bf\u03c5 \u03c3\u03bf\u03c5 \u03b1\u03c1\u03b5\u03c3\u03b5\u03b9!<\/span><\/p><\/blockquote>\n<p><span style=\"font-weight: 400;\">\u039c\u03b5\u03c3\u03b1 \u03c3\u03c4\u03b7 \u03bd\u03b5\u03b1 \u03c7\u03c1\u03bf\u03bd\u03b9\u03b1, \u03b2\u03b1\u03bb\u03b5 \u03b5\u03bd\u03b1 \u03c3\u03c4\u03bf\u03c7\u03bf, \u03b2\u03c1\u03b5\u03c2 \u03c4\u03bf\u03bd \u03c4\u03c1\u03bf\u03c0\u03bf \u03c0\u03bf\u03c5 \u03c3\u03b5 \u03b5\u03c5\u03c7\u03b1\u03c1\u03b9\u03c3\u03c4\u03b5\u03b9 \u03ba\u03b1\u03b9 \u03bc\u03b5\u03c7\u03c1\u03b9 \u03c4\u03bf \u03ba\u03b1\u03bb\u03bf\u03ba\u03b1\u03b9\u03c1\u03b9 \u03b5\u03c4\u03bf\u03b9\u03bc\u03b1\u03c3\u03bf\u03c5 \u03bd\u03b1 \u03bc\u03b9\u03bb\u03b1\u03c2 \u03bf\u03c0\u03c9\u03c2 \u03c0\u03b1\u03bd\u03c4\u03b1 \u03c4\u03bf \u03bf\u03bd\u03b5\u03b9\u03c1\u03b5\u03c5\u03bf\u03c3\u03bf\u03c5\u03bd..<\/span><\/p>\n","protected":false},"excerpt":{"rendered":"<p>\u201c\u0397 \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03b9\u03b1 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03b1\u03c5\u03b8\u03b5\u03bd\u03c4\u03b9\u03ba\u03b7 \u03b3\u03bb\u03c9\u03c3\u03c3\u03b1 \u03b5\u03b9\u03bd\u03b1\u03b9 \u03bf \u03bc\u03bf\u03bd\u03bf\u03c2 \u03b4\u03c1\u03bf\u03bc\u03bf\u03c2\u201d. \u03a4\u03b9 \u03b5\u03bd\u03bd\u03bf\u03b5\u03b9 \u03bf \u03c0\u03bf\u03b9\u03b7\u03c4\u03b7\u03c2; \u039b\u03b9\u03b3\u03b5\u03c2 \u03b1\u03ba\u03bf\u03bc\u03b7 \u03bc\u03b5\u03c1\u03b5\u03c2 \u03c0\u03c1\u03b9\u03bd \u03c4\u03bf 2022 \u03c0\u03b5\u03c1\u03b1\u03c3\u03b5\u03b9 \u03c3\u03c4\u03b7\u03bd \u03b9\u03c3\u03c4\u03bf\u03c1\u03b9\u03b1 \u03ba\u03b1\u03b9 \u03c0\u03b1\u03c1\u03b1\u03b4\u03b9\u03b4\u03c9 \u03c4\u03b9\u03c2 \u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03b9\u03b5\u03c2 \u03c9\u03c1\u03b5\u03c2 \u03bc\u03b1\u03b8\u03b7\u03bc\u03b1\u03c4\u03c9\u03bd \u03b3\u03b9\u03b1 \u03c6\u03b5\u03c4\u03bf\u03c2 \u03ba\u03b1\u03b9 \u03c3\u03c5\u03bd\u03b5\u03c7\u03b9\u03b6\u03c9 \u03bd\u03b1 \u03b8\u03c5\u03bc\u03b9\u03b6\u03c9 \u03c3\u03c4\u03bf\u03c5\u03c2 \u03bc\u03b